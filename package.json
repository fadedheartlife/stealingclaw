{
    "name": "wallet-dapp",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Real-time admin full-control wallet dApp trading platform with live crypto prices and multi-wallet integration",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:production": "vite build --mode production",
        "preview": "vite preview",
        "lint": "eslint src --ext js,jsx",
        "test": "vitest run",
        "test:watch": "vitest",
        "format": "prettier --write \"src/**/*.{js,jsx,css}\""
    },
    "dependencies": {
        "@wagmi/connectors": "^7.1.6",
        "@wagmi/core": "^3.3.2",
        "@web3modal/wagmi": "^5.1.11",
        "express-rate-limit": "^8.3.2",
        "parse": "^5.3.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^7.12.0",
        "viem": "^2.21.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.0",
        "@vitejs/plugin-react": "^5.1.2",
        "autoprefixer": "^10.4.23",
        "eslint": "^9.18.0",
        "eslint-plugin-react": "^7.37.0",
        "eslint-plugin-react-hooks": "^5.1.0",
        "postcss": "^8.5.0",
        "prettier": "^3.4.0",
        "tailwindcss": "^4.1.0",
        "vite": "^5.4.21",
        "vitest": "^2.1.0"
    },
    "engines": {
        "node": "20.x"
