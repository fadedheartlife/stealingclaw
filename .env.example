VITE_BACK4APP_JS_KEY=your_back4app_js_key
VITE_BACK4APP_SERVER_URL=https://parseapi.back4app.com
VITE_BACK4APP_LIVE_QUERY_URL=wss://your_project.b4a.io

# Back4App AI Agent
VITE_BACK4APP_AGENT_ID=9e49b410-27bf-489f-9470-2cd8d465d545
VITE_BACK4APP_AGENT_URL=https://containers.back4app.com/agents/9e49b410-27bf-489f-9470-2cd8d465d545

# Required: WalletConnect
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: Alchemy RPC
VITE_ALCHEMY_API_KEY=your_alchemy_api_key

# Optional: CoinGecko API (free tier works without key)
VITE_COINGECKO_API_KEY=

# SECRET: Admin panel path (change this to something only you know)
# The admin login will be at /{VITE_ADMIN_PATH}/login — do NOT share publicly
VITE_ADMIN_PATH=_cp
